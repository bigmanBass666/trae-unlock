{"$schema": "http://json-schema.org/draft-07/schema#", "$id": "https://trae-mod.dev/schemas/project-rules.json", "title": "Trae Mod Project Rules Schema", "description": "跨会话 Agent 规则框架的 JSON Schema 定义，用于验证 project-rules.yaml 的结构和内容", "type": "object", "required": ["schema_version", "project_name", "last_updated", "rules"], "properties": {"schema_version": {"type": "string", "description": "规则文件的 schema 版本号", "pattern": "^\\d+\\.\\d+\\.\\d+$", "examples": ["1.0.0", "1.1.0"]}, "project_name": {"type": "string", "description": "项目名称", "minLength": 1, "examples": ["Trae Mod - Trae IDE 定制框架"]}, "last_updated": {"type": "string", "description": "最后更新时间（ISO 8601 格式）", "format": "date-time", "examples": ["2026-04-19T21:41:00+08:00"]}, "maintainer": {"type": "string", "description": "维护者信息"}, "global_config": {"type": "object", "description": "全局配置项", "properties": {"default_enforcement_level": {"$ref": "#/definitions/enforcement_level"}, "session_startup": {"type": "object", "properties": {"auto_load_required_reading": {"type": "boolean", "default": true}, "on_load_failure": {"type": "string", "enum": ["strict", "warn", "ignore"], "default": "strict"}}}}}, "rules": {"type": "array", "description": "规则定义列表", "items": {"$ref": "#/definitions/rule"}, "minItems": 1}, "_statistics": {"type": "object", "description": "规则统计信息（可选，供参考）"}}, "definitions": {"rule": {"type": "object", "required": ["id", "type", "priority", "title", "description", "condition", "action", "enforcement_level", "metadata"], "properties": {"id": {"type": "string", "description": "规则唯一标识符", "pattern": "^[A-Z]{2,}-\\d{3}$", "examples": ["RR-001", "PAC-002", "MB-001", "PB-001", "DC-001"]}, "type": {"$ref": "#/definitions/rule_type"}, "priority": {"$ref": "#/definitions/priority"}, "title": {"type": "string", "description": "规则简短标题", "minLength": 1, "maxLength": 100}, "description": {"type": "string", "description": "规则的详细描述，支持多行文本"}, "condition": {"$ref": "#/definitions/condition"}, "action": {"$ref": "#/definitions/action"}, "enforcement_level": {"$ref": "#/definitions/enforcement_level"}, "metadata": {"$ref": "#/definitions/metadata"}}}, "rule_type": {"type": "string", "description": "规则类型枚举", "enum": ["RequiredReading", "PreActionCheck", "MandatoryBehavior", "ProhibitedBehavior", "DocumentationContract"], "enumDescriptions": {"RequiredReading": "必读文档: 新会话启动时必须按优先级读取的文档列表", "PreActionCheck": "操作前检查: 执行敏感操作前必须满足的前置条件", "MandatoryBehavior": "强制行为: 执行特定操作时必须遵循的方式", "ProhibitedBehavior": "禁止行为: 禁止执行的危险操作及替代方案", "DocumentationContract": "文档更新契约: 完成特定操作后必须同步更新的文档"}}, "priority": {"type": "string", "description": "规则优先级", "enum": ["critical", "high", "medium", "low"], "default": "medium", "enumDescriptions": {"critical": "最高优先级，必须严格遵守，违反将导致严重后果", "high": "高优先级，强烈建议遵守", "medium": "中等优先级，一般情况应遵守", "low": "低优先级，仅供参考"}}, "enforcement_level": {"type": "string", "description": "执行级别", "enum": ["required", "recommended", "informational"], "default": "recommended", "enumDescriptions": {"required": "必须执行，不可跳过", "recommended": "建议执行，特殊情况下可跳过并说明原因", "informational": "仅作提示，不强制执行"}}, "condition": {"type": "object", "description": "触发条件（WHEN 子句）", "required": ["when", "trigger"], "properties": {"when": {"type": "string", "description": "触发时机", "enum": ["session.startup", "before_action", "during_action", "after_action", "action_attempted", "session_end"], "enumDescriptions": {"session.startup": "会话启动时", "before_action": "执行操作前", "during_action": "执行操作过程中", "after_action": "执行操作后", "action_attempted": "尝试执行操作时（用于禁止行为）", "session_end": "会话结束时"}}, "trigger": {"type": "string", "description": "具体的触发条件描述", "minLength": 1}, "action_type": {"type": "string", "description": "关联的操作类型（可选）"}, "action_sequence": {"type": "array", "description": "操作序列（用于检测连续操作）", "items": {"type": "string"}}, "detection": {"type": "string", "description": "检测方式或条件"}, "detection_patterns": {"type": "array", "description": "检测模式列表（用于敏感数据扫描）", "items": {"type": "string"}}, "prohibited_commands": {"type": "array", "description": "禁止的命令列表", "items": {"type": "string"}}, "action_types": {"type": "array", "description": "触发的操作类型列表", "items": {"type": "string"}}}}, "action": {"type": "object", "description": "要求的行为（THEN 子句）", "required": ["then"], "properties": {"then": {"type": "string", "description": "主要行为描述", "minLength": 1}, "steps": {"type": "array", "description": "详细步骤列表", "items": {"type": "string"}}, "checklist": {"type": "array", "description": "前置检查清单", "items": {"type": "object", "required": ["item"], "properties": {"item": {"type": "string", "description": "检查项描述"}, "required": {"type": "boolean", "description": "是否必需"}}}}, "failure_action": {"type": "string", "description": "检查失败时的处理方式"}, "target_documents": {"type": "array", "description": "目标文档路径列表", "items": {"type": "string"}}, "alternative_steps": {"type": "array", "description": "替代方案步骤列表", "items": {"type": "string"}}, "alternatives": {"type": "object", "description": "替代方案映射", "additionalProperties": {"type": "string"}}, "required_command": {"type": "string", "description": "必须执行的命令"}, "max_delay_seconds": {"type": "number", "description": "最大延迟时间（秒）"}, "prohibited_actions": {"type": "array", "description": "禁止的操作列表", "items": {"type": "string"}}, "required_fields": {"type": "array", "description": "必填字段定义列表", "items": {"type": "object", "required": ["name", "type"], "properties": {"name": {"type": "string"}, "type": {"type": "string"}, "description": {"type": "string"}}}}, "format_pattern": {"type": "string", "description": "格式正则表达式模式"}, "examples": {"type": "array", "description": "示例列表", "items": {"type": "string"}}, "update_targets": {"type": "array", "description": "文档更新目标列表", "items": {"type": "object", "required": ["target_file"], "properties": {"target_file": {"type": "string", "description": "目标文件路径"}, "required": {"type": "boolean", "description": "是否必须更新"}, "condition": {"type": "string", "description": "更新条件"}, "section": {"type": "string", "description": "更新的章节"}, "content_template": {"type": "string", "description": "内容模板"}, "action": {"type": "string", "description": "对目标文件的操作"}}}, "deadline": {"type": "string", "description": "更新截止时间要求", "enum": ["immediate", "before_next_action", "within_5_minutes", "before_session_end"]}}}, "metadata": {"type": "object", "description": "规则元数据", "required": ["created_at", "version"], "properties": {"created_at": {"type": "string", "description": "创建日期", "format": "date"}, "version": {"type": "string", "description": "规则版本号", "pattern": "^\\d+\\.\\d+\\.\\d+$"}, "author": {"type": "string", "description": "作者"}, "applicable_modes": {"type": "array", "description": "适用的操作模式", "items": {"type": "string", "enum": ["exploration", "modification", "testing", "all"]}, "default": ["all"]}, "related_files": {"type": "array", "description": "相关文件列表", "items": {"type": "string"}}, "last_updated": {"type": "string", "description": "最后更新日期", "format": "date"}, "risk_level": {"type": "string", "description": "风险级别", "enum": ["low", "medium", "high", "critical"]}, "lesson_learned": {"type": "string", "description": "经验教训"}, "known_issue": {"type": "string", "description": "已知问题"}, "importance_note": {"type": "string", "description": "重要性备注"}, "security_impact": {"type": "string", "description": "安全影响评估", "enum": ["low", "medium", "high", "critical"]}, "consequence": {"type": "string", "description": "违规后果"}, "principle": {"type": "string", "description": "设计原则"}, "warning": {"type": "string", "description": "警告信息"}}}}}, "examples": [{"schema_version": "1.0.0", "project_name": "示例项目", "last_updated": "2026-01-01T00:00:00+08:00", "rules": [{"id": "RR-001", "type": "RequiredReading", "priority": "critical", "title": "示例必读规则", "description": "这是一个示例规则", "condition": {"when": "session.startup", "trigger": "新会话开始"}, "action": {"then": "读取文档", "steps": ["步骤1", "步骤2"]}, "enforcement_level": "required", "metadata": {"created_at": "2026-01-01", "version": "1.0.0"}}]}]}